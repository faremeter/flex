{
  "name": "@faremeter/flex-solana",
  "version": "0.1.0",
  "description": "Flex Payment Scheme SDK for Solana",
  "license": "LGPL-3.0-only",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "require": "./dist/src/index.js",
