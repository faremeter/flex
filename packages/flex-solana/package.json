    }
  },
  "scripts": {
    "tsc": "tsc --build"
  },
  "dependencies": {
    "@faremeter/info": "^0.17.1",
    "@faremeter/logs": "^0.17.1",
    "@faremeter/types": "^0.17.1",
    "@solana/kit": "^6.1.0",
    "@solana/program-client-core": "^6.1.0",
    "arktype": "^2.1.0"
