#!/usr/bin/env opsh
# shellcheck shell=bash

PROGRAM_ID="EcfUgNgDXmBx4Xns2qZLE54xpM7V1N6PL8MdDW1syujS"
PROGRAM_SO="target/deploy/flex.so"
LEDGER_DIR="test-ledger"
RPC_URL="http://127.0.0.1:8899"
RPC_PORT=8899
MAX_WAIT=30

[[ $# -gt 0 ]] || log::fatal "usage: with-validator <command> [args...]"
[[ -f $PROGRAM_SO ]] || log::fatal "$PROGRAM_SO not found, run 'make build-anchor' first"

if curl -s "$RPC_URL" -X POST -H "Content-Type: application/json" \
    -d '{"jsonrpc":"2.0","id":1,"method":"getHealth"}' >/dev/null 2>&1; then
    log::fatal "port $RPC_PORT is already in use"
fi

validator-cleanup() {
    if [[ -n ${VALIDATOR_PID:-} ]]; then
        kill "$VALIDATOR_PID" 2>/dev/null || true
        wait "$VALIDATOR_PID" 2>/dev/null || true
    fi
    rm -rf "$LEDGER_DIR"
}

exit::trigger validator-cleanup

rm -rf "$LEDGER_DIR"

log::info "starting solana-test-validator..."

solana-test-validator \
    --bpf-program "$PROGRAM_ID" "$PROGRAM_SO" \
    --ledger "$LEDGER_DIR" \
    --quiet &
VALIDATOR_PID=$!

HEALTHY=false
for ((i = 0; i < MAX_WAIT; i++)); do
    if curl -s "$RPC_URL" -X POST -H "Content-Type: application/json" \
        -d '{"jsonrpc":"2.0","id":1,"method":"getHealth"}' >/dev/null 2>&1; then
        HEALTHY=true
        break
    fi
    sleep 1
done

$HEALTHY || log::fatal "validator did not become healthy within ${MAX_WAIT}s"

log::info "validator healthy, running command..."

"$@"
